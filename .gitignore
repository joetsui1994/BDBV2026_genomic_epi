node_modules/
dist/
.DS_Store

# Raw geo/metadata source data — the derived public/data/health-zones.geojson
# (built via `npm run data:zones`) is committed instead.
public/data/shapefiles/
public/data/health_zone_metadata*.csv
# Raw, identifiable line-list exports (age/sex/date_of_death) must never be committed —
# only the de-identified public/data/linelist_data.csv is tracked.
public/data/*BD_LABO*.csv
# (public/data/linelist_data.csv IS tracked — the sample-distribution panel reads it at runtime)
public/data/*.legacy.csv
public/data/linelist_data.legacy*.csv
# Lab line-list processing artifacts — intermediate, some carry identifiable fields
# (date_of_death/age/sex). Not consumed by the app; must never be published.
public/lab_linelist_processed/
# Raw BEAST MCMC logs — large build inputs (~12 MB). The derived public/data/skygrid.json +
# exponential.json are committed instead; keep the logs locally to regenerate via
# `npm run data:skygrid` / `npm run data:exponential`.
data-raw/*.log
